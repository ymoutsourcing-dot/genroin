# 元老院 PC Agent 設定（.env にコピーして埋める）
# .env はコミット禁止（.gitignore で除外済）

# GAS Web App URL（/exec で終わる）
GAS_URL=https://script.google.com/macros/s/AKfycbz.../exec

# GAS の SECRET と完全一致させる（_gas_code.gs の `const SECRET = ...`）
SECRET=put-your-40-char-secret-here

# poll 間隔（ms）。3000 だと無料 GAS の実行時間クォータ（90 min/日）を超える可能性あり
# 推奨：5000（≈3.2h/日）／ 10000（≈1.6h/日）
POLL_MS=5000
